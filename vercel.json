{
  "buildCommand": "npx prisma generate && npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/api/slack/oauth", "destination": "/api/slack/oauth" },
    { "source": "/api/slack/callback", "destination": "/api/slack/callback" },
    { "source": "/api/auth/google", "destination": "/api/auth/google" },
    { "source": "/api/auth/google/callback", "destination": "/api/auth/google/callback" }
  ]
}